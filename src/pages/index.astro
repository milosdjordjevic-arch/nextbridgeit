---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Approach from '../components/Approach.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="NextBridge IT — Software teams you can put weight on"
  description="NextBridge IT builds and scales senior-led software teams for companies worldwide. AI engineering, dedicated teams, staff augmentation, project delivery, cloud & DevOps, and product engineering — from Belgrade, for the world."
>
  <Nav />
  <main id="main">
    <Hero />
    <Services />
    <Approach />
    <About />
    <Contact />
  </main>
  <Footer />
</Base>

<script>
  import { initMotion } from '../scripts/motion';
  initMotion();
</script>
